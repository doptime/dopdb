{
  "name": "dopdb",
  "version": "0.1.0-alpha.1",
  "description": "One TypeScript source of truth for DB + API: native types, no codegen, no double-write. Browser client (fetch) and Node server (MongoDB) from the same schema.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    }
  },
  "files": ["dist/src", "dist/bin"],
  "bin": {
    "dopdb-spec": "./dist/bin/spec.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:types": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "mongodb": "^6.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
