{
  "name": "dopdb",
  "version": "0.1.0-alpha.1",
  "description": "One schema, two equivalent engines (Go + TypeScript), one wire protocol. Declare a collection once and get native types, runtime validation, a typed browser client (fetch), and a Node + MongoDB server — no codegen, no double-write. Redis-compatible data structures (Hash/String/List/Set/ZSet) on MongoDB.",
  "type": "module",
  "license": "MIT",
  "author": "doptime",
  "homepage": "https://github.com/doptime/dopdb/tree/main/ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doptime/dopdb.git",
    "directory": "ts"
  },
  "bugs": {
    "url": "https://github.com/doptime/dopdb/issues"
  },
  "keywords": [
    "mongodb",
    "typescript",
    "schema",
    "orm",
    "odm",
    "redis",
    "redisdb",
    "doptime",
    "typed-client",
    "fullstack",
    "nextjs",
    "rpc",
    "multi-tenant",
    "jwt"
  ],
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src",
    "dist/bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "dopdb-spec": "./dist/bin/spec.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:types": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "mongodb": "^6.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
